{
  "name": "table-tennis-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:theme": "ng test --include='**/*.theme.spec.ts'",
    "test:theme:ci": "ng test --include='**/*.theme.spec.ts' --watch=false --browsers=ChromeHeadless",
    "test:all": "ng test --code-coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:auth": "cypress run --spec 'cypress/e2e/01-auth/**'",
    "cypress:run:season": "cypress run --spec 'cypress/e2e/02-season/**'",
    "cypress:run:tournament": "cypress run --spec 'cypress/e2e/03-tournament/**'",
    "cypress:run:scoring": "cypress run --spec 'cypress/e2e/04-match-scoring/**'",
    "cypress:run:player": "cypress run --spec 'cypress/e2e/05-player/**'",
    "cypress:run:e2e": "cypress run --spec 'cypress/e2e/06-full-flow/**'",
    "cypress:run:all": "cypress run --spec 'cypress/e2e/**/*.cy.ts'"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "bmad-method": "^4.44.3",
    "lucide-angular": "^0.554.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.10",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "cypress": "^15.11.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
