# Table Tennis League Environment Variables

# PostgreSQL Database
POSTGRES_DB=table_tennis_db
POSTGRES_USER=ttl_user
POSTGRES_PASSWORD=secure_ttl_password

# Django Backend Settings
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-12345
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://table-tennis.local
