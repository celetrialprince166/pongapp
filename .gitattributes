# Normalize line endings to LF in the repo and on checkout.
# Critical: shell scripts and configs run inside Linux containers and break with CRLF.
* text=auto eol=lf

*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.template  text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
